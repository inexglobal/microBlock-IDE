{
  "name": "mblock",
  "version": "3.1.0-beta.2",
  "description": "microBlock IDE (offline version)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:wifi": "electron-rebuild -f -w wifi-control",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:linux": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.microblock.app",
    "productName": "microBlock IDE",
    "asar": false,
    "files": [
      "!Arduino/*"
    ],
    "buildDependenciesFromSource": true,
    "npmRebuild": false,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/favicon.ico"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/favicon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/favicon.png",
      "category": "Development"
    },
    "fileAssociations": [
      {
        "ext": "mby",
        "name": "MBY",
        "description": "microBlock project file",
        "icon": "build/favicon.ico",
        "role": "Editor"
      }
    ]
  }
}
